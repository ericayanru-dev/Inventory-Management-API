{ // tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pnpm: dev",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "dev"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*nodemon.*",
          "endsPattern": "^.*watching.*"
        }
      }
    },
    {
      "label": "pnpm: start",
      "type": "shell",
      "command": "pnpm",
      "args": ["start"],
      "group": "build",
      "isBackground": false
    }
  ]
}
